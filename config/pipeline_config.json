{
  "assets": {
    "root": "/Game/Tools/Semantic",
    "material_name": "M_PP_SemanticMask_Auto",
    "rt_rgb_name": "RT_RGB",
    "rt_mask_name": "RT_MASK"
  },
  "capture": {
